# OpenSprint Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# AI Provider API Keys (at least one required)
# =============================================================================

# Claude — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Cursor — get your key at Cursor → Settings → Integrations → User API Keys
CURSOR_API_KEY=

# =============================================================================
# Optional
# =============================================================================

# Filesystem root for the folder browser (default: current working directory).
# Set this to the parent directory that contains your repositories so the
# folder picker can see and select them.
# Example: /Users/you/Documents/GitHub
# OPENSPRINT_FS_ROOT=

# Backend API port (default: 3100)
# PORT=3100

# Set to "production" for production mode
# NODE_ENV=development
